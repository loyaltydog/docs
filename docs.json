{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "LoyaltyDog",
  "description": "Developer documentation for the LoyaltyDog loyalty, gift card, and wallet pass platform.",
  "colors": {
    "primary": "#E02040",
    "light": "#FF4D6A",
    "dark": "#A00C24"
  },
  "favicon": "/logo/logomark.png",
  "logo": {
    "light": "/logo/logofull.png",
    "dark": "/logo/logofull.png",
    "href": "https://loyalty.dog"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "MCP",
            "pages": [
              "mcp/overview",
              "mcp/installation",
              "mcp/clients"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/overview",
              "integrations/shopify",
              "integrations/square",
              "integrations/clover",
              "integrations/eposnow",
              "integrations/zapier",
              "integrations/custom"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/webhooks",
              "guides/wallet-passes",
              "guides/reporting"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "resources/changelog",
              "resources/support",
              "resources/status"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": {
          "source": "https://api.loyalty.dog/openapi.json",
          "directory": "api-reference"
        }
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API status",
          "href": "https://status.loyalty.dog",
          "icon": "signal-bars"
        },
        {
          "anchor": "Marketing site",
          "href": "https://loyalty.dog",
          "icon": "globe"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/loyaltydog",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@loyalty.dog"
      },
      {
        "label": "Contact",
        "href": "https://loyalty.dog/contact-us"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get an API key",
      "href": "https://loyalty.dog/contact-us"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/loyaltydog",
      "linkedin": "https://www.linkedin.com/company/loyaltydog",
      "x": "https://x.com/loyaltydog"
    },
    "links": [
      {
        "header": "Product",
        "items": [
          { "label": "Marketing site", "href": "https://loyalty.dog" },
          { "label": "Pricing", "href": "https://loyalty.dog/pricing" },
          { "label": "Contact", "href": "https://loyalty.dog/contact-us" }
        ]
      },
      {
        "header": "Developers",
        "items": [
          { "label": "API reference", "href": "/api-reference" },
          { "label": "MCP server", "href": "/mcp/overview" },
          { "label": "Status", "href": "https://status.loyalty.dog" }
        ]
      },
      {
        "header": "Legal",
        "items": [
          { "label": "Terms of service", "href": "https://loyalty.dog/loyalty-program-terms-service" },
          { "label": "Privacy policy", "href": "https://loyalty.dog/privacy-policy" }
        ]
      }
    ]
  }
}
